# ============================================================================
#  NEXTOCK — Variables de entorno para PRODUCCIÓN
#  Copia este archivo a .env y rellena los valores.
# ============================================================================

# ---- Base de datos PostgreSQL ----
# OPCIÓN A (recomendada en la nube): una sola URL, tal como la da Neon/Supabase/Render.
#   Si defines DATABASE_URL, se ignoran las variables DB_* de abajo y se activa SSL solo.
DATABASE_URL=

# OPCIÓN B: variables sueltas (úsalas si dejas DATABASE_URL vacío, p. ej. en la VM).
DB_HOST=db
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=cambia_esta_contraseña
DB_NAME=nextock
DB_SSL=false              # pon "true" si tu Postgres exige SSL (Neon/Supabase)
DB_SYNCHRONIZE=true       # crea/actualiza las tablas automáticamente

# ---- Seguridad (JWT) ----
JWT_SECRET=pon_aqui_un_secreto_largo_y_aleatorio
JWT_EXPIRES_IN=8h

# ---- Microservicio de ML (interno al contenedor) ----
ML_SERVICE_URL=http://127.0.0.1:8000
ML_DATA_DIR=/app/MLNEXTOCK/data

# ---- Frontend Angular compilado (lo sirve NestJS) ----
FRONTEND_DIST=/app/frontend/browser

# ---- Puerto ----
# En Render NO hace falta tocarlo (lo inyecta solo). En la VM, déjalo en 3000.
PORT=3000

# ---- Correo (opcional, HU-20). Si los dejas vacíos, el envío es SIMULADO ----
MAIL_FROM=nextockreportes@gmail.com
MAIL_USER=
MAIL_PASS=
